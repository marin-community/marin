# Only lib/iris/ and lib/rigging/ are needed in the build context.
# Exclude everything else, then selectively re-include.
*

!lib/iris/pyproject.toml
!lib/iris/hatch_build.py
!lib/iris/src/
!lib/iris/examples/
!lib/iris/config/
!lib/iris/dashboard/dist/

!lib/rigging/

# Exclude build artifacts within included paths
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/node_modules
**/.venv
