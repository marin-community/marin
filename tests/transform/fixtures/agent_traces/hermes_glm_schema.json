            "_type": "Value",
            "dtype": "string"
          }
        }
      }
    },
    {
      "name": "tools",
      "type": {
        "_type": "Value",
        "dtype": "string"
      }
    },
    {
      "name": "category",
      "type": {
        "_type": "Value",
        "dtype": "string"
      }
    },
    {
      "name": "subcategory",
      "type": {
        "_type": "Value",
        "dtype": "string"
      }
    },
    {
      "name": "task",
      "type": {
        "_type": "Value",
        "dtype": "string"
      }
    }
  ]
